# server/.env.example
# Copy this file to .env and fill in values
# NEVER commit your actual .env file to Git (it's in .gitignore)
# RESOURCE: https://www.npmjs.com/package/dotenv

# Server port
PORT=3001

# JWT secret — used to sign and verify tokens
# In production: use a long random string (run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Token expiration
JWT_EXPIRES_IN=7d

# Environment
NODE_ENV=development
